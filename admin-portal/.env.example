# RAG backend (no trailing slash) - e.g. Cloud Run
RAG_BACKEND_URL=https://YOUR-BACKEND-SERVICE.run.app

# Same as backend FILE_PREFIX (default kb-) so semantic file_id slugs match
# FILE_PREFIX=kb-

# This admin portal's public URL (for OAuth redirect)
PUBLIC_BASE_URL=http://127.0.0.1:8088
# Production example:
# PUBLIC_BASE_URL=https://rag-admin-XXXXX.run.app

# Google OAuth (create OAuth 2.0 Client in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match Authorized redirect URI in Google Console exactly:
OAUTH_REDIRECT_URI=http://127.0.0.1:8088/auth/callback

# Comma-separated allowlist (after Google login, email must match)
ALLOWED_ADMIN_EMAILS=user@example.com,admin@example.com

# Sign session cookies
SESSION_SECRET=change-me-to-a-long-random-string

# Local dev: helps OAuth if state storage is flaky (use false on Cloud Run)
# ALLOW_OAUTH_STATE_BYPASS=true

# Local dev only: skip Google login (NEVER in production)
DEV_SKIP_OAUTH=false
# When DEV_SKIP_OAUTH=true, this mock user must match ALLOWED if list is non-empty
DEV_MOCK_EMAIL=dev@local.test
